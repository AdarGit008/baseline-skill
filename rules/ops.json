{
  "rules": [
    {
      "id": "OPS-01",
      "title": "Structured logging is wired in",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://12factor.net/logs",
      "lesson": "12-factor XI: logs as event streams",
      "rationale": "Ad-hoc print/console logging can't be parsed, correlated, or leveled in prod; a structured logger is the minimum operability bar.",
      "fix": "Adopt a structured logger (pino/winston, zap/zerolog, structlog/slog) writing to stdout.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          "src/**/*",
          "app/**/*",
          "internal/**/*",
          "cmd/**/*",
          "lib/**/*",
          "**/*.ts",
          "**/*.js",
          "**/*.py",
          "**/*.go"
        ],
        "pattern": "import\\s+[^\\n;]*(pino|winston|bunyan|zap|zerolog|structlog|logrus|slog)|require\\(['\"](pino|winston|bunyan)['\"]|from\\s+structlog|\"log/slog\"|zap\\.New|zerolog\\.New\\b|pino\\(|winston\\.createLogger|logging\\.getLogger\\(|logrus\\.New",
        "mode": "present"
      }
    },
    {
      "id": "OPS-02",
      "title": "A health/readiness endpoint exists",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://kubernetes.io/docs/tasks/configure-pod-container/configure-liveness-readiness-startup-probes/",
      "lesson": "orchestrators need a probe target",
      "rationale": "Without a health endpoint an orchestrator can't tell if the service is alive/ready, so it can't route or restart it correctly.",
      "fix": "Add a /health (and /ready) route and point a liveness/readiness probe at it.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          "src/**/*",
          "app/**/*",
          "internal/**/*",
          "cmd/**/*",
          "**/*.ts",
          "**/*.js",
          "**/*.py",
          "**/*.go"
        ],
        "pattern": "(app\\.(get|use)|router\\.(get|handle|HandleFunc)|mux\\.Handle(Func)?|http\\.HandleFunc|fastify\\.get|\\.route\\(|@(app\\.route|Get|GetMapping|RequestMapping)|gin\\.|echo\\.(GET|Any))[^\\n]{0,90}(/health|/healthz|/readyz|/livez|actuator/health)|@(app\\.route|router\\.get)\\([^\\n]{0,40}(health|ready)",
        "mode": "present"
      }
    },
    {
      "id": "OPS-03",
      "title": "Graceful shutdown on SIGTERM",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://12factor.net/disposability",
      "lesson": "12-factor IX: fast startup + graceful shutdown",
      "rationale": "A service that ignores SIGTERM drops in-flight requests on every deploy/scale-down.",
      "fix": "Handle SIGTERM: stop accepting new work, drain in-flight, close listeners, then exit.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          "src/**/*",
          "app/**/*",
          "internal/**/*",
          "cmd/**/*",
          "**/*.ts",
          "**/*.js",
          "**/*.py",
          "**/*.go"
        ],
        "pattern": "process\\.on\\(['\"]SIGTERM|signal\\.Notify\\([^\\n]*SIGTERM|@PreDestroy|addShutdownHook|trap\\s+['\"]?SIGTERM|signal\\.signal\\(signal\\.SIGTERM|add_signal_handler\\([^\\n]*SIGTERM|onShutdown|gracefulShutdown",
        "mode": "present"
      }
    },
    {
      "id": "OPS-04",
      "title": "Outbound calls are time-bounded/guarded",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://sre.google/sre-book/handling-overload/",
      "lesson": "bound your dependencies",
      "rationale": "An unbounded call to a slow dependency cascades into resource exhaustion; timeouts + retry/breaker contain the blast. Heuristic.",
      "fix": "Set explicit timeouts on HTTP/DB clients and add retry or circuit-breaker logic on critical paths.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          "src/**/*",
          "app/**/*",
          "internal/**/*",
          "cmd/**/*",
          "config/**/*",
          "**/*.ts",
          "**/*.js",
          "**/*.py",
          "**/*.go"
        ],
        "pattern": "timeout\\s*[:=]\\s*\\w|WithTimeout|context\\.WithTimeout|AbortSignal\\.timeout|setTimeout\\([^\\n]*abort|\\.timeout\\(|Timeout\\s*=\\s*\\w|resilience4j|opossum|gobreaker|failsafe|tenacity|polly|circuit.?breaker|httpx\\.[A-Za-z]+\\([^\\n]*timeout|axios[^\\n]*timeout",
        "mode": "present"
      }
    },
    {
      "id": "OPS-05",
      "title": "An operational runbook exists",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://sre.google/workbook/",
      "lesson": "SRE Workbook: on-call needs runbooks",
      "rationale": "When it breaks at 3am, an on-call needs a rollback + escalation path, not to reverse-engineer the system live.",
      "fix": "Add a runbook (runbooks/, docs/runbooks/, or RUNBOOK.md) covering rollback steps and an escalation/on-call contact.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "file-contains",
        "globs": [
          "runbooks/**/*.md",
          "docs/runbooks/**/*.md",
          "RUNBOOK.md",
          "docs/oncall.md",
          "docs/on-call.md"
        ],
        "flags": "i",
        "pattern": "(?=[\\s\\S]*(rollback|roll back|revert|redeploy))(?=[\\s\\S]*(escalat|on-call|on call|pager|paging|contact))"
      }
    },
    {
      "id": "OPS-06",
      "title": "A service descriptor declares owner + lifecycle",
      "category": "ops",
      "severity": "warn",
      "profile": "service",
      "applies_to": [
        "service"
      ],
      "source": "https://backstage.io/docs/features/software-catalog/descriptor-format/",
      "lesson": "catalog: every service has an owner",
      "rationale": "A parseable descriptor (owner + lifecycle/tier) is how a platform knows who to page and how critical the service is.",
      "fix": "Add catalog-info.yaml (Backstage), opslevel.yml, or cortex.yaml with owner and lifecycle populated.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "file-contains",
        "globs": [
          "catalog-info.yaml",
          "catalog-info.yml",
          "opslevel.yml",
          "opslevel.yaml",
          "cortex.yaml",
          ".backstage/catalog-info.yaml"
        ],
        "flags": "im",
        "pattern": "(?=[\\s\\S]*^\\s*owner\\s*:\\s*\\S)(?=[\\s\\S]*^\\s*(lifecycle|tier|level)\\s*:\\s*\\S)"
      }
    }
  ]
}
