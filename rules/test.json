{
  "rules": [
    {
      "id": "TEST-01",
      "title": "Automated tests exist",
      "category": "test",
      "severity": "blocker",
      "lesson": "SW-2 tests assert the spec",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "rationale": "Acceptance criteria backed by nothing are prose.",
      "fix": "Add at least one real test under test/ or *.test.*/*_test.py.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "any-file",
        "globs": [
          "**/*.test.*",
          "**/*.spec.*",
          "**/*_test.py",
          "**/*_test.go",
          "**/*Test.java",
          "**/*Tests.java",
          "**/*Test.kt",
          "**/*Test.cs",
          "**/*Tests.cs",
          "**/*_test.rb",
          "**/*_test.exs",
          "**/test_*.py",
          "test/**/*",
          "tests/**/*",
          "src/test/**/*",
          "**/__tests__/**/*"
        ]
      }
    },
    {
      "id": "TEST-02",
      "title": "Failure paths are tested (negative tests)",
      "category": "test",
      "severity": "warn",
      "lesson": "SW-2 a test must try to break the promise",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "rationale": "A test that never exercises the failing input passes without proving anything.",
      "fix": "For every 'must raise / must reject / must 4xx', add a test asserting it (toThrow / rejects / pytest.raises).",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          "**/*.test.*",
          "**/*.spec.*",
          "**/*_test.py",
          "**/*_test.go",
          "test/**/*",
          "tests/**/*"
        ],
        "pattern": "toThrow(Error)?\\b|\\.rejects\\b|rejects\\.to|assert\\.throws|assert\\.rejects|assertRaises|pytest\\.raises|\\.raises\\(|toReject\\b|StatusCode\\(4|status.{0,6}4\\d\\d|assert\\.Error\\(|require\\.Error\\(",
        "mode": "present"
      }
    },
    {
      "id": "TEST-03",
      "title": "Red-on-arrival guards for 'must-never-exist' invariants",
      "category": "test",
      "severity": "manual",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "lesson": "SW-3 enforce invariants by absence",
      "rationale": "An invariant about something that must NOT exist is only real if a pinned test (e.g. a table/enum count) goes red when it appears.",
      "fix": "Add a count/allow-list assertion for each 'must never appear' rule, then record it in the sign-off ledger.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "judgment",
      "check": {
        "kind": "signoff"
      }
    },
    {
      "id": "TEST-04",
      "title": "Acceptance criteria reconciled against reference code",
      "category": "test",
      "severity": "manual",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "lesson": "SW-2 criteria vs their own example code",
      "rationale": "Specs whose acceptance criteria contradict their own reference impl create wrong-either-way forks.",
      "fix": "Before 'ready', confirm every enum/field named in a criterion exists in its type def; record sign-off.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "judgment",
      "check": {
        "kind": "signoff"
      }
    },
    {
      "id": "TEST-05",
      "title": "Mutation testing, if used, is gated",
      "category": "test",
      "severity": "warn",
      "profile": "advanced",
      "source": "https://stryker-mutator.io/docs/stryker-js/configuration/",
      "lesson": "SW-2 tests must be able to fail",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "rationale": "A mutation run that never fails the build is decoration; a break-threshold >0 turns a weak suite red.",
      "fix": "In stryker.conf.* set thresholds.break to a value >0; or run mutmut in --CI mode with a floor.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "any-of",
        "checks": [
          {
            "kind": "grep",
            "globs": [
              "stryker.conf.*",
              "stryker.config.*",
              ".stryker.conf.*"
            ],
            "pattern": "\"?break\"?\\s*:\\s*[1-9]",
            "mode": "present"
          },
          {
            "kind": "signoff"
          }
        ]
      }
    },
    {
      "id": "TEST-06",
      "title": "Flaky-test quarantine is disciplined",
      "category": "test",
      "severity": "manual",
      "profile": "advanced",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "source": "https://docs.google.com/",
      "lesson": "SW-2 skips need owner+deadline",
      "rationale": "A growing pile of skipped tests silently erodes coverage unless each skip carries an owner+reason+deadline and the total stays under a cap.",
      "fix": "Give every quarantined test an owner+deadline (marker or central register) and cap the total; record sign-off.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "judgment",
      "check": {
        "kind": "signoff"
      }
    },
    {
      "id": "TEST-07",
      "title": "A coverage floor is declared and enforced",
      "category": "test",
      "severity": "warn",
      "profile": "advanced",
      "source": "https://docs.codecov.com/docs/commit-status",
      "lesson": "a coverage regression should exit non-zero",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "rationale": "A coverage number nobody gates on drifts down; a fail-under threshold makes a regression fail the build.",
      "fix": "Set a numeric floor: coverage.py fail_under, jest coverageThreshold, a codecov target, or --cov-fail-under in CI.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "any-of",
        "checks": [
          {
            "kind": "grep",
            "globs": [
              "pyproject.toml",
              ".coveragerc",
              "setup.cfg",
              "tox.ini"
            ],
            "pattern": "fail_under\\s*=\\s*[1-9]",
            "mode": "present"
          },
          {
            "kind": "grep",
            "globs": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml",
              "Makefile",
              "package.json"
            ],
            "pattern": "--cov-fail-under[= ]*[1-9]|check-coverage|coverage-threshold",
            "mode": "present"
          },
          {
            "kind": "json-field",
            "globs": [
              "package.json"
            ],
            "path": "jest.coverageThreshold",
            "assert": "present"
          },
          {
            "kind": "grep",
            "globs": [
              "codecov.yml",
              ".codecov.yml"
            ],
            "pattern": "target:\\s*[0-9]",
            "mode": "present"
          }
        ]
      }
    }
  ]
}
