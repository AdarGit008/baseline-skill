{
  "rules": [
    {
      "id": "SEC-01",
      "title": "No high-signal secrets committed",
      "category": "security",
      "severity": "blocker",
      "applies_to": "all",
      "source": "https://github.com/gitleaks/gitleaks",
      "lesson": "12-factor: a repo could go open-source at any moment",
      "rationale": "A committed private key or cloud credential is an immediate breach and survives in git history.",
      "fix": "Remove the secret, rotate it, and add a secret-scanner (gitleaks/trufflehog) to CI.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "grep",
        "tracked_only": true,
        "globs": [
          "**/*"
        ],
        "exclude_globs": [
          "**/*.md",
          "**/*.lock",
          "*.lock",
          "**/*.snap",
          "**/fixtures/**",
          "**/testdata/**",
          "**/__snapshots__/**",
          "**/*.min.js",
          "**/*.map"
        ],
        "pattern": "-----BEGIN (RSA|EC|OPENSSH|DSA|PGP)? ?PRIVATE KEY-----|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_\\-]{35}|xox[baprs]-[0-9A-Za-z\\-]{10,}|gh[pousr]_[0-9A-Za-z]{36}",
        "flags": "m",
        "raw_scan": true,
        "mode": "absent"
      }
    },
    {
      "id": "SEC-02",
      "title": "Real .env files are git-ignored, not committed",
      "category": "security",
      "severity": "blocker",
      "applies_to": "all",
      "source": "https://12factor.net/config",
      "lesson": "12-factor III: config in the environment, not the repo",
      "rationale": "A committed .env leaks live secrets; only the template (.env.example) belongs in the tree.",
      "fix": "git rm --cached the .env file, add '.env' to .gitignore, rotate anything exposed.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "any-file",
        "tracked_only": true,
        "mode": "absent",
        "globs": [
          ".env",
          ".env.local",
          ".env.development",
          ".env.production",
          ".env.prod",
          ".env.staging",
          "**/.env",
          ".env.*.local"
        ],
        "allow": [
          ".env.example",
          ".env.sample",
          ".env.template",
          ".env.dist",
          "**/.env.example",
          "**/.env.sample",
          "**/.env.template"
        ]
      }
    },
    {
      "id": "SEC-03",
      "title": "Third-party CI actions pinned to a commit SHA",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Pinned-Dependencies",
      "rationale": "A mutable action ref (@v4, @main) lets an upstream tag move under you and run arbitrary code in a token-bearing runner.",
      "fix": "Pin every external 'uses:' to a full 40-char commit SHA (append a # v4 comment for readability).",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ],
        "pattern": "uses:\\s*['\"]?[A-Za-z0-9._-]+/[A-Za-z0-9._-]+(?:/[^@'\"\\s]+)?@(?![0-9a-f]{40}\\b)[^\\s'\"]+",
        "flags": "m",
        "mode": "absent"
      }
    },
    {
      "id": "SEC-04",
      "title": "No dangerous CI workflow patterns",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Dangerous-Workflow",
      "rationale": "Interpolating untrusted event text into a run: script, or checking out PR-head under pull_request_target, are the two canonical CI RCE paths. Heuristic — treat hits as review flags.",
      "fix": "Move untrusted input into an env: var and reference it as \"$VAR\"; never checkout the PR head under pull_request_target with write scope.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ],
        "pattern": "pull_request_target[\\s\\S]{0,400}?ref:\\s*\\$\\{\\{\\s*github\\.event\\.pull_request\\.head|run:[\\s\\S]{0,200}?\\$\\{\\{\\s*github\\.event\\.(issue|pull_request|comment|review)\\.[a-zA-Z_.]*(title|body|head_ref)",
        "mode": "absent"
      }
    },
    {
      "id": "SEC-05",
      "title": "Automated dependency-update tool configured",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Dependency-Update-Tool",
      "rationale": "A committed lockfile freezes deps at a point in time; without an update bot those pins silently rot into known-CVE territory.",
      "fix": "Add .github/dependabot.yml or renovate.json; or wire an SCA step (npm audit / pip-audit / osv-scanner) into CI.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "any-of",
        "checks": [
          {
            "kind": "any-file",
            "globs": [
              ".github/dependabot.yml",
              ".github/dependabot.yaml",
              "renovate.json",
              ".github/renovate.json",
              ".renovaterc",
              ".renovaterc.json",
              ".renovaterc.json5",
              ".snyk"
            ]
          },
          {
            "kind": "grep",
            "globs": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ],
            "pattern": "npm audit|pip-audit|osv-scanner|trivy|snyk test|dependency-review",
            "mode": "present"
          }
        ]
      }
    },
    {
      "id": "SEC-06",
      "title": "Security policy names a reporting channel",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://docs.github.com/code-security/getting-started/adding-a-security-policy-to-your-repository",
      "lesson": "repolinter / Scorecard Security-Policy",
      "rationale": "A SECURITY.md that exists but names no way to report a vuln is presence theater; the reporting channel is the load-bearing part.",
      "fix": "Add SECURITY.md with a reporting email or a link to your GitHub security advisories, plus supported-versions info.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "file-contains",
        "globs": [
          "SECURITY.md",
          "docs/SECURITY.md",
          ".github/SECURITY.md"
        ],
        "pattern": "[\\w.+-]+@[\\w-]+\\.[\\w.-]+|github\\.com/[^\\s)]+/security/advisories|/security/advisories/new|https?://[^\\s)]*(security|report|disclos|hackerone|bugcrowd)|report.{0,40}(email|https?://|@)"
      }
    },
    {
      "id": "SEC-07",
      "title": "No committed binary/executable artifacts",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Binary-Artifacts (HIGH risk)",
      "rationale": "A committed binary can't be reviewed and may hide malware or an unreproducible build; source should build the artifact, not ship it.",
      "fix": "Remove the binary, build it from source in CI, and gitignore the output path (allow-list genuine test fixtures/vendor).",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "any-file",
        "tracked_only": true,
        "mode": "absent",
        "globs": [
          "**/*.exe",
          "**/*.dll",
          "**/*.so",
          "**/*.dylib",
          "**/*.class",
          "**/*.jar",
          "**/*.a",
          "**/*.wasm",
          "**/*.o",
          "**/*.pyc"
        ],
        "allow": [
          "**/testdata/**",
          "**/fixtures/**",
          "**/vendor/**",
          "**/node_modules/**",
          "**/*.test.wasm"
        ]
      }
    },
    {
      "id": "SEC-08",
      "title": "A committed SBOM exists in a recognized format",
      "category": "security",
      "severity": "warn",
      "profile": "advanced",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "source": "https://www.cisa.gov/sbom",
      "lesson": "NTIA minimum elements",
      "rationale": "An SBOM lets downstream consumers answer 'am I affected by CVE-X' without cloning and building.",
      "fix": "Generate and commit a CycloneDX (*.cdx.json) or SPDX (*.spdx.json) SBOM in CI.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "any-file",
        "globs": [
          "**/*.cdx.json",
          "**/bom.json",
          "**/cyclonedx.json",
          "**/*.spdx.json",
          "**/sbom.json",
          "**/*.spdx"
        ]
      }
    },
    {
      "id": "SEC-09",
      "title": "Static code-scanning is configured",
      "category": "security",
      "severity": "warn",
      "profile": "advanced",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard SAST",
      "rationale": "CodeQL/Semgrep in CI catches injection and unsafe-API classes that unit tests miss; it should fail the build, not merely annotate.",
      "fix": "Add a CodeQL or Semgrep workflow and configure it to fail on findings (semgrep --error, or a required check-run).",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ],
        "pattern": "codeql-action|github/codeql|semgrep|snyk code|sonarqube|sonarcloud",
        "mode": "present"
      }
    },
    {
      "id": "SEC-10",
      "title": "Release provenance/signing is present",
      "category": "security",
      "severity": "warn",
      "profile": "advanced",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "source": "https://slsa.dev/",
      "lesson": "SLSA L1+ provenance",
      "rationale": "Signed provenance lets consumers verify an artifact was built by your pipeline, not swapped in transit.",
      "fix": "Add actions/attest-build-provenance, slsa-github-generator, or cosign signing to your release workflow.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "any-of",
        "checks": [
          {
            "kind": "grep",
            "globs": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml"
            ],
            "pattern": "attest-build-provenance|slsa-github-generator|sigstore|cosign|gpg --sign|--sign",
            "mode": "present"
          },
          {
            "kind": "any-file",
            "globs": [
              "**/*.intoto.jsonl",
              "**/*.sigstore",
              "**/*.sig"
            ]
          }
        ]
      }
    },
    {
      "id": "SEC-11",
      "title": "CI grants a least-privilege GITHUB_TOKEN",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Token-Permissions",
      "rationale": "A workflow with no top-level permissions block (or write-all) hands every step a broad token; a compromised action or dependency can push code or publish packages. Default read-only, grant write per-job.",
      "fix": "Add 'permissions: {contents: read}' (or 'read-all') at the top of each workflow; grant write scopes only inside the jobs that need them.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "deterministic",
      "check": {
        "kind": "workflow-permissions",
        "globs": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ]
      }
    },
    {
      "id": "SEC-12",
      "title": "A secret-scanning gate is wired in",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://github.com/gitleaks/gitleaks",
      "lesson": "prevention gate vs point-in-time detection (complements SEC-01)",
      "rationale": "SEC-01 catches secrets committed as of now; a scanner wired into CI or pre-commit fails future builds when a new secret lands.",
      "fix": "Add gitleaks/trufflehog/detect-secrets to CI or .pre-commit-config.yaml (and commit its config).",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "any-of",
        "checks": [
          {
            "kind": "grep",
            "globs": [
              ".github/workflows/*.yml",
              ".github/workflows/*.yaml",
              ".gitlab-ci.yml"
            ],
            "strip_comments": true,
            "pattern": "gitleaks|trufflehog|detect-secrets|ggshield",
            "mode": "present"
          },
          {
            "kind": "grep",
            "globs": [
              ".pre-commit-config.yaml",
              ".pre-commit-config.yml"
            ],
            "strip_comments": true,
            "pattern": "gitleaks|detect-secrets|trufflehog",
            "mode": "present"
          }
        ]
      }
    },
    {
      "id": "SEC-13",
      "title": "A dependency vulnerability scan runs in CI",
      "category": "security",
      "severity": "warn",
      "profile": "advanced",
      "applies_to": [
        "node",
        "python",
        "service",
        "library"
      ],
      "source": "https://github.com/ossf/scorecard/blob/main/docs/checks.md",
      "lesson": "Scorecard Vulnerabilities (SCA is not an update-tool)",
      "rationale": "An update bot (SEC-05: dependabot/renovate) opens PRs but is not a vuln scanner; a dedicated SCA step surfaces known CVEs in the pipeline.",
      "fix": "Add an SCA step to CI: osv-scanner / govulncheck / pip-audit / npm audit / trivy / grype / snyk test / owasp dependency-check.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml",
          ".gitlab-ci.yml",
          "Makefile",
          "package.json"
        ],
        "strip_comments": true,
        "pattern": "osv-scanner|govulncheck|pip-audit|npm audit|pnpm audit|yarn audit|trivy|grype|snyk test|dependency-check",
        "mode": "present"
      }
    },
    {
      "id": "SEC-14",
      "title": "Pre-commit hooks pinned to an immutable rev",
      "category": "security",
      "severity": "warn",
      "applies_to": "all",
      "source": "https://pre-commit.com/",
      "lesson": "immutable rev, not a floating branch (analog of SEC-03)",
      "rationale": "A pre-commit hook pinned to main/master/HEAD pulls whatever that branch points at — the same mutable-ref supply-chain risk SEC-03 guards for CI actions. Skips if there's no pre-commit config.",
      "fix": "Pin each 'rev:' in .pre-commit-config.yaml to a tag or 40-char SHA, never a branch name.",
      "sources": [
        "tree"
      ],
      "on_unreachable": "skip",
      "contexts": [
        "check",
        "reconcile"
      ],
      "certainty": "heuristic",
      "check": {
        "kind": "grep",
        "globs": [
          ".pre-commit-config.yaml",
          ".pre-commit-config.yml"
        ],
        "flags": "im",
        "strip_comments": true,
        "pattern": "rev:\\s*['\"]?(main|master|HEAD|develop|trunk|latest)\\b['\"]?\\s*$",
        "mode": "absent"
      }
    }
  ]
}
